# Application
/.env
/.env.backup
/.env.*.local
/.env.production

# Dependencies
/vendor/
/node_modules/

# Build & compiled assets
/public/build/
/public/hot
/public/storage

# Laravel cache & bootstrap
/bootstrap/cache/*
!/bootstrap/cache/.gitkeep

# Laravel storage (keep structure, ignore content)
/storage/*.key
/storage/app/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*
!/storage/app/.gitkeep
!/storage/app/public/.gitkeep
!/storage/framework/.gitkeep
!/storage/framework/cache/.gitkeep
!/storage/framework/cache/data/.gitkeep
!/storage/framework/sessions/.gitkeep
!/storage/framework/testing/.gitkeep
!/storage/framework/views/.gitkeep
!/storage/logs/.gitkeep

# Testing
/.phpunit.result.cache
/coverage/
/.pest/

# IDEs & editors
/.idea/
/.vscode/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# Composer
composer.phar
auth.json

# NPM / Vite
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock

# Misc
*.log
*.cache
*.swp
*~